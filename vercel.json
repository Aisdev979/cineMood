{
  "version": 2,
  "builds": [
    { "src": "server/server.js", "use": "@vercel/node" },
    { "src": "clients/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "server/server.js" },
    { "src": "/styles.css", "dest": "clients/styles.css" },
    { "src": "/app.js", "dest": "clients/app.js" },
    { "src": "/(.*)", "dest": "clients/index.html" }
  ]
}
